{
	"name": "dracpurp",
	"version": "1.0.0",
	"displayName": "Dracpurp",
	"description": "A polished purple and dark cyberpunk evolution of the Dracula theme.",
	"publisher": "dracpurp",
	"license": "MIT",
	"scripts": {
		"build": "node ./scripts/build.js",
		"lint": "node ./scripts/lint.js",
		"package": "vsce package -o ./bin/dracpurp.vsix",
		"vscode:prepublish": "npm run build",
		"vsce-publish": "vsce publish",
		"updateTheme": "npm run vscode:prepublish && npm run package"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/luizomf/omtheme"
	},
	"engines": {
		"vscode": "^1.13.0"
	},
	"categories": [
		"Themes"
	],
	"keywords": [
		"dracpurp",
		"purple",
		"dark",
		"cyberpunk",
		"dracula",
		"theme",
		"color-theme"
	],
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#100e12",
		"theme": "dark"
	},
	"contributes": {
		"themes": [
			{
				"label": "Dracpurp",
				"uiTheme": "vs-dark",
				"path": "./theme/dracpurp.json"
			},
			{
				"label": "Dracpurp (Night Owl Italic)",
				"uiTheme": "vs-dark",
				"path": "./theme/dracpurp-nightOwlItalic.json"
			},
			{
				"label": "Dracpurp (No Italic)",
				"uiTheme": "vs-dark",
				"path": "./theme/dracpurp-noItalic.json"
			}
		]
	},
	"devDependencies": {
		"js-yaml": "^3.14.0",
		"prettier": "^2.2.1",
		"tinycolor2": "^1.4.2",
		"vsce": "^1.87.1"
	},
	"dependencies": {
		"lodash": "^4.17.21"
	}
}
